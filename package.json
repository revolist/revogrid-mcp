{
  "name": "@revogrid-mcp/server",
  "private": true,
  "version": "0.1.0",
  "description": "Hosted MCP server for structured RevoGrid knowledge retrieval.",
  "packageManager": "pnpm@10.4.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "reindex": "tsx scripts/reindex.ts",
    "backfill:symbols": "tsx scripts/backfillSymbols.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@revogrid-mcp/content-model": "workspace:*",
    "@revogrid-mcp/ingestion": "workspace:*",
    "@revogrid-mcp/shared": "workspace:*",
    "fastify": "^5.2.1",
    "pg": "^8.13.3",
    "pgvector": "^0.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.0.2",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vitest": "^3.0.8"
  }
}
