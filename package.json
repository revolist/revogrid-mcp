{
  "name": "revogrid-mcp",
  "private": true,
  "version": "0.1.0",
  "description": "Hosted MCP server for structured RevoGrid knowledge retrieval.",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "pnpm --filter @revogrid-mcp/server dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed.ts",
    "reindex": "tsx scripts/reindex.ts",
    "backfill:symbols": "tsx scripts/backfillSymbols.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.0.2",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vitest": "^3.0.8",
    "zod": "^3.24.2"
  }
}
